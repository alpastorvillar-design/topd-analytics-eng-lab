[sqlfluff]
dialect = bigquery
templater = dbt
max_line_length = 120

# Reglas excluidas (convenciones de estilo elegidas en el proyecto):
#
# LT01  Aligned 'as' keyword with multiple spaces. Convención de columnas
#       alineadas para legibilidad. Se mantiene aquí.
# LT02  Indentation expectations. Las queries multilínea con cases inline
#       y subqueries no encajan con el indent automático.
# LT08  Blank line after CTE closing bracket. Preferencia de estilo.
# LT09  Single-line select targets. Multi-line es lo que usamos.
# ST02  Use COALESCE over simple CASE. Se mantienen los CASE explícitos
#       cuando aportan claridad en revisión.
# ST06  Positional select ordering. Las PKs van primero por convención.
# ST07  USING vs ON. Preferimos USING cuando los nombres de columna casan.
# AL01  Implicit table aliasing. Usamos el patrón "from x as t" mezclado
#       con "from x t". Ambos son válidos.
# AM04  Ambiguous wildcard en CTE pass-throughs.
# RF02  Unqualified column refs en CTEs.
# RF03  References qualified.
# RF04  Keywords como identifiers (`date` column en agg_daily_business_kpis
#       sale por aliasing de appointment_date para el join key).
# CV02  COALESCE vs IFNULL.
# CV11  Cast vs ::

exclude_rules = LT01, LT02, LT08, LT09, ST02, ST06, ST07, AL01, AM04, RF02, RF03, RF04, CV02, CV11

[sqlfluff:indentation]
tab_space_size = 4
indented_joins = false
indented_using_on = true

[sqlfluff:layout:type:comma]
spacing_before = touch
line_position = trailing

[sqlfluff:rules:capitalisation.keywords]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.identifiers]
extended_capitalisation_policy = lower

[sqlfluff:rules:capitalisation.functions]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.literals]
capitalisation_policy = lower

[sqlfluff:rules:capitalisation.types]
extended_capitalisation_policy = lower

[sqlfluff:templater:dbt]
project_dir = ./dbt_mediconnect
profiles_dir = ~/.dbt
